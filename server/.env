# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geotrack

# Legacy MongoDB (kept for data migration script only)
MONGODB_URI=mongodb://localhost:27017/geotrack

# Server Config
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# Tracker URL - This should be your Cloudflare tunnel URL
# The tunnel script will auto-update this, or set manually
TRACKER_URL=https://image-attendance-age-friendship.trycloudflare.com

# n8n Integration
N8N_CHAT_WEBHOOK=http://localhost:5678/webhook/geotrack-chat
N8N_ORDER_WEBHOOK=http://localhost:5678/webhook/geotrack-order

# Ollama AI
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
